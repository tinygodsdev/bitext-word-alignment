# S3-compatible object storage — gallery example PNG upload (`make examples-upload`)
# Copy to bitext/.env and fill in values.

OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_BUCKET_NAME=
OBJECT_STORAGE_ORIGIN_ENDPOINT=
# Required for CDN URLs on the site (unless OBJECT_STORAGE_PUBLIC_BASE is set)
OBJECT_STORAGE_CDN_ENDPOINT=

# Optional overrides
# OBJECT_STORAGE_PREFIX=examples
# OBJECT_STORAGE_PUBLIC_BASE=https://your-bucket.fra1.cdn.digitaloceanspaces.com/examples

# Optional: purge Spaces CDN after upload (DigitalOcean API — not Spaces access keys)
# Create a Personal Access Token at https://cloud.digitalocean.com/account/api/tokens
# DIGITALOCEAN_API_TOKEN=
# DO_CDN_ENDPOINT_ID=          # optional; resolved from bucket + ORIGIN_ENDPOINT if omitted
# OBJECT_STORAGE_CDN_PURGE=0   # set to disable auto-purge
# OBJECT_STORAGE_CDN_PURGE_PATHS=examples/*

# Render script (optional)
# PREVIEW_URL=http://127.0.0.1:4173
# PREVIEW_PORT=4173
